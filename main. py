    if message.author.bot or not message.guild:
        return

    user_id = str(message.author.id)
    data = load_data()

    if user_id not in data:
        data[user_id] = {"xp": 0, "level": 0}

    current_xp = data[user_id]["xp"]
    current_level = data[user_id]["level"]

