import discord
from discord.ext import commands
import os

# إعداد البوت والبريفكس (تقدر تغير الـ ! لأي علامة تانية أنت عايزها)
intents = discord.Intents.default()
intents.message_content = True
bot = commands.Bot(command_prefix="!", intents=intents)

@bot.event
async def on_ready():
    print(f'تم تشغيل البوت بنجاح باسم: {bot.user}')

@bot.command()
async def ping(ctx):
    await ctx.send(f'pong! 🏓 السرعة: {round(bot.latency * 1000)}ms')

# تشغيل البوت باستخدام المتغير البيئي (Token)
token = os.environ.get("DISCORD_TOKEN")
if token:
    bot.run(token)
else:
    print("خطأ: لم يتم العثور على DISCORD_TOKEN في المتغيرات البيئية!")
